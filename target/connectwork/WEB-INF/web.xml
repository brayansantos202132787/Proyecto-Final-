        <url-pattern>/api/perfil/freelancer/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CategoriaServlet</servlet-name>
        <servlet-class>com.connectwork.service.CategoriaService</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CategoriaServlet</servlet-name>
        <url-pattern>/api/categorias/*</url-pattern>
