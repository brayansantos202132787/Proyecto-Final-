<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee          https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <display-name>ConnectWork API</display-name>
    <!-- ===== FILTERS ===== -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.connectwork.filter.CorsFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>
    <filter>
        <filter-name>JwtFilter</filter-name>
        <filter-class>com.connectwork.filter.JwtFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>JwtFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>
    <!-- ===== SERVLETS ===== -->
    <servlet>
        <servlet-name>AuthServlet</servlet-name>
        <servlet-class>com.connectwork.controller.AuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AuthServlet</servlet-name>
        <url-pattern>/api/auth/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>UsuarioServlet</servlet-name>
        <servlet-class>com.connectwork.controller.UsuarioServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UsuarioServlet</servlet-name>
        <url-pattern>/api/usuarios/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>PerfilClienteServlet</servlet-name>
        <servlet-class>com.connectwork.controller.PerfilClienteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PerfilClienteServlet</servlet-name>
        <url-pattern>/api/perfil/cliente/*</url-pattern>
