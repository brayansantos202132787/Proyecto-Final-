        <servlet-name>PropuestaServlet</servlet-name>
        <servlet-class>com.connectwork.controller.PropuestaServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PropuestaServlet</servlet-name>
        <url-pattern>/api/propuestas/*</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ContratoServlet</servlet-name>
        <servlet-class>com.connectwork.controller.ContratoServlet</servlet-class>
    </servlet>
